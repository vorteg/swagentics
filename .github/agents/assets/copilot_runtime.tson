[_meta]
description = "Dynamic registry of GitHub Copilot Chat runtime capabilities. AUTO-GENERATED from extension package.tson \u2014 do not edit manually."
generated_at = "2026-04-28T16:50:20.675175+00:00"
source_extension = "github.copilot-chat-0.45.1"
extension_version = "0.45.1"
update_command = "uv run .github/hooks/scripts/generate_copilot_runtime.py"


[slash_commands_by_mode]
[[slash_commands_by_mode.ask_mode]]
command = "/explain"
description = "Explain how the code in your active editor works"
available_when = "always"


[[slash_commands_by_mode.ask_mode]]
